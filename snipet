sem_t sem;
sem_init(&sem, 0, 2);  // max 2 wątki w sekcji krytycznej

sem_wait(&sem);         // wchodzę do sekcji
printf("Wątek w sekcji\n");
sem_post(&sem);         // wychodzę, zwalniam miejsce

pthread_mutex_t m = PTHREAD_MUTEX_INITIALIZER;
pthread_cond_t  c = PTHREAD_COND_INITIALIZER;
int ready = 0;

// wątek czeka
pthread_mutex_lock(&m);
while (!ready)
    pthread_cond_wait(&c, &m);
printf("Warunek spełniony!\n");
pthread_mutex_unlock(&m);

// inny wątek sygnalizuje
pthread_mutex_lock(&m);
ready = 1;
pthread_cond_signal(&c);
pthread_mutex_unlock(&m);

pthread_barrier_t barrier;
pthread_barrier_init(&barrier, NULL, 3);  // 3 wątki muszą dojść

printf("Wątek robi coś...\n");
pthread_barrier_wait(&barrier);           // czeka na pozostałe wątki
printf("Wszyscy wątki gotowe – ruszamy dalej\n");
